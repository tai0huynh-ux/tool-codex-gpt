{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@codex-context-bridge/contracts": ["packages/contracts/src/index.ts"],
      "@codex-context-bridge/database": ["packages/database/src/index.ts"],
      "@codex-context-bridge/project-registry": ["packages/project-registry/src/index.ts"],
      "@codex-context-bridge/project-detector": ["packages/project-detector/src/index.ts"],
      "@codex-context-bridge/local-transport": ["packages/local-transport/src/index.ts"],
      "@codex-context-bridge/file-store": ["packages/file-store/src/index.ts"],
      "@codex-context-bridge/secret-scanner": ["packages/secret-scanner/src/index.ts"],
      "@codex-context-bridge/context-builder": ["packages/context-builder/src/index.ts"],
      "@codex-context-bridge/memory-engine": ["packages/memory-engine/src/index.ts"],
      "@codex-context-bridge/workflow-engine": ["packages/workflow-engine/src/index.ts"],
      "@codex-context-bridge/assisted-chatgpt": ["packages/assisted-chatgpt/src/index.ts"],
      "@codex-context-bridge/response-router": ["packages/response-router/src/index.ts"]
    }
  }
}
