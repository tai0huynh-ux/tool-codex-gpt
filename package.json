{
  "name": "codex-context-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "clean": "pnpm -r --if-present clean",
    "diagnostics:export": "node scripts/export-diagnostics.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "migrations:check": "node scripts/sync-initial-migration.mjs --check",
    "migrations:generate": "node scripts/sync-initial-migration.mjs",
    "native:restore-node": "node scripts/restore-node-native.mjs",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-windows.ps1",
    "prepare:internal-beta": "node scripts/prepare-internal-beta.mjs",
    "smoke:packaged:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-packaged-windows.ps1",
    "smoke:native-host:win": "node scripts/smoke-native-host.mjs artifacts/desktop/win-unpacked/resources/CodexContextBridgeNativeHost.exe",
    "smoke:installed-native-host:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-installed-native-host.ps1",
    "smoke:installed-chatgpt:win": "tsx scripts/smoke-installed-chatgpt.ts",
    "test:pilot-packaged-restart": "node scripts/pilot-packaged-restart-acceptance.mjs",
    "status": "node scripts/project-status.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:workflow-e2e": "vitest run tests/integration/recoverable-workflow.test.ts",
    "test:project-pilot": "vitest run tests/integration/project-pilot.test.ts",
    "test:e2e": "pnpm run test:workflow-e2e && playwright test",
    "test:internal-beta-uat": "vitest run tests/integration/recoverable-workflow.test.ts packages/context-builder/src/index.test.ts packages/assisted-chatgpt/src/index.test.ts packages/response-router/src/index.test.ts packages/workflow-engine/src/index.test.ts && playwright test",
    "test:watch": "vitest",
    "test:codex-spike": "tsx tests/spikes/codex-sdk-spike.ts",
    "verify": "pnpm run migrations:check && pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:e2e && pnpm run build"
  },
  "devDependencies": {
    "@openai/codex-sdk": "0.144.5",
    "@playwright/test": "^1.55.0",
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
