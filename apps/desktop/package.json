{
  "name": "@codex-context-bridge/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsup src/main.ts src/preload.ts --format esm --out-dir dist/main --clean && vite build",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codex-context-bridge/contracts": "workspace:*",
    "@codex-context-bridge/database": "workspace:*",
    "@codex-context-bridge/project-detector": "workspace:*",
    "@codex-context-bridge/project-registry": "workspace:*",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^43.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^8.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
