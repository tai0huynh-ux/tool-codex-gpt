{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-context-bridge.local/schemas/handoff-envelope.v1.json",
  "title": "HandoffEnvelope v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "handoffId",
    "correlationId",
    "source",
    "target",
    "project",
    "destination",
    "objective",
    "userInstructions",
    "constraints",
    "currentState",
    "completedWork",
    "unresolvedIssues",
    "attachments",
    "expectedResponse",
    "createdAt"
  ],
  "properties": {
    "protocolVersion": { "const": "1.0" },
    "handoffId": { "type": "string", "minLength": 1 },
    "parentHandoffId": { "type": "string", "minLength": 1 },
    "correlationId": { "type": "string", "minLength": 1 },
    "source": { "enum": ["user", "chatgpt", "codex"] },
    "target": { "enum": ["chatgpt", "codex"] },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "confidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "repoRoot": { "type": "string", "minLength": 1 },
        "gitRemote": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["existing-thread", "new-thread"] },
        "conversationId": { "type": "string", "minLength": 1 },
        "codexThreadId": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "existing-thread" } } },
          "then": {
            "anyOf": [
              {
                "properties": { "conversationId": { "type": "string", "minLength": 1 } },
                "required": ["conversationId"]
              },
              {
                "properties": { "codexThreadId": { "type": "string", "minLength": 1 } },
                "required": ["codexThreadId"]
              }
            ]
          }
        }
      ]
    },
    "objective": { "type": "string", "minLength": 1 },
    "userInstructions": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "currentState": { "type": "string" },
    "completedWork": { "type": "array", "items": { "type": "string" } },
    "unresolvedIssues": { "type": "array", "items": { "type": "string" } },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "sha256", "size", "inclusionReason"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size": { "type": "integer", "minimum": 0 },
          "mediaType": { "type": "string", "minLength": 1 },
          "inclusionReason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "expectedResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "schemaVersion"],
      "properties": {
        "type": { "const": "analysis-and-codex-prompt" },
        "schemaVersion": { "type": "string", "minLength": 1 }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
